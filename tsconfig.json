{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2020",
    "sourceMap": true,
    "outDir": "./dist",
    "strict": true,
    "incremental": true,
    "skipLibCheck": true,
    "typeRoots": ["./src/@types"],
    "resolveJsonModule": true,
    "paths": {
      "@/src/*": ["./src/*"],
      "@/bot/*": ["./src/modules/bot/*"],
      "@/types/*": ["./src/@types/*"],
      "@/common/*": ["./src/common/*"],
      "@/authentication/*": ["./src/authentication/*"],
      "@/dauthentication/*": ["./src/authentication/*"],
      "@/config/*": ["./src/config/*"],
      "@/database/*": ["./src/database/*"],
      "@/jobs/*": ["./src/jobs/*"],
      "@/mails/*": ["./src/mails/*"],
      "@/modules/*": ["./src/modules/*"],
      "@/providers/*": ["./src/providers/*"],
      "@/web3Modules/*": ["./src/web3Modules/*"],
      "@/dweb3Modules/*": ["./src/web3Modules/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
