# Core Environment Settings
NODE_ENV=development               # Node.js environment (development | staging | production)
NODE_DB_ENV=development            # Database environment mode; ensures correct DB selection
JWT_BEARER_SECRET="ffarrfafraerfeffgfgfgfgfgfgr"   # Secret key for signing/verifying JWT bearer tokens
PORT=5001                          # Port on which the backend HTTP server will run

# Auth Server (OAuth2/OIDC)
AUTH_SERVER_ISSUER="http://localhost:9000"
AUTH_SERVER_JWKS_URI="http://localhost:9000/oauth2/jwks"
# AUTH_SERVER_AUDIENCE=            # Optional: validate aud claim if set
FRONTEND_URL="http://localhost:3000"


# Database Configuration
DB_CLIENT="postgres"                     
DB_DATABASE="thesis_module"                   
DB_USER="postgres"                    
DB_PASSWORD="123456"                       
DB_HOST="localhost"                       
DB_PORT="5432"                          


# Redis Configuration
REDIS_PORT=6379                        # Redis port (e.g., 6379)
REDIS_HOST="localhost"                        # Redis host or hostname
REDIS_URL=                         # Full Redis connection URL if required


# Email Server Configuration
MAILER_HOST=                       # SMTP server host
MAILER_PORT=                       # SMTP port (e.g., 465 for SSL, 587 for TLS)
MAILER_SECURE=                     # true/false depending on SSL usage
MAILER_USER=                       # SMTP username
MAILER_PASSWORD=                   # SMTP password
MAILER_FROM=                       # Default "From" email address for outgoing mail

